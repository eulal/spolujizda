{
	"name": "eulal/spolujizda",
	"description": "Webová aplikace pro organizaci sdílených jízd na semináře a akce.",
	"keywords": ["spolujizda", "carsharing", "nette", "php"],
	"homepage": "https://github.com/eulal/spolujizda",
	"type": "project",
	"license": "GPL-3.0-or-later",
	"authors": [
		{
			"name": "eulal",
			"email": "it-eulal@riseup.net"
		}
	],
	"require": {
		"php": ">= 8.2",
		"nette/application": "^3.2.3",
		"nette/bootstrap": "^3.2.6",
		"nette/caching": "^3.2",
		"nette/database": "^3.2",
		"nette/di": "^3.2",
		"nette/forms": "^3.2",
		"nette/http": "^3.3",
		"nette/mail": "^4.0",
		"nette/robot-loader": "^4.0",
		"nette/security": "^3.2",
		"nette/utils": "^4.0",
		"latte/latte": "^3.1",
		"tracy/tracy": "^2.10",
		"nette/assets": "^1.0"
	},
	"require-dev": {
		"nette/tester": "^2.5",
		"phpstan/phpstan": "^2.1",
		"phpstan/extension-installer": "^1.4",
		"nette/phpstan-rules": "^1.0@dev",
		"symfony/thanks": "^1"
	},
	"autoload": {
		"psr-4": {
			"App\\": "app"
		}
	},
	"scripts": {
		"phpstan": "phpstan analyse",
		"tester": "tester tests -s"
	},
	"minimum-stability": "stable",
	"config": {
		"allow-plugins": {
			"symfony/thanks": true,
			"phpstan/extension-installer": true
		}
	}
}
