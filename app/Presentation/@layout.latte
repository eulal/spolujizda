<!DOCTYPE html>
<html lang="cs">
<head>
	<meta charset="utf-8">
	<meta name="viewport" content="width=device-width, initial-scale=1">
	<title>{ifset title}{include title|stripHtml} | {/ifset}{$appName}</title>
	<meta name="description" content="Plánování sdílených jízd pro účastníky seminářů a akcí.">

	<link rel="icon" href="{$basePath}/favicon.ico" sizes="any">
	<link rel="icon" href="{$basePath}/favicon.png" type="image/png">
	<link rel="icon" href="{$basePath}/favicon-32x32.png" type="image/png" sizes="32x32">
	<link rel="icon" href="{$basePath}/favicon-16x16.png" type="image/png" sizes="16x16">
	<link rel="apple-touch-icon" href="{$basePath}/apple-touch-icon.png" sizes="180x180">

	<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"
		  integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
	<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">

	{asset 'css/style.css'}
</head>

<body>
	<nav class="navbar navbar-expand-lg navbar-dark">
		<div class="container">
			<a class="navbar-brand" n:href="Home:default">
				<i class="bi bi-{$appIcon}"></i> {$appName}
			</a>
			<button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
				<span class="navbar-toggler-icon"></span>
			</button>
			<div class="collapse navbar-collapse" id="navbarNav">
				<ul class="navbar-nav me-auto">
					<li class="nav-item">
						<a class="nav-link" n:href="Home:default">
							<i class="bi bi-calendar-event"></i> Akce
						</a>
					</li>
				</ul>
				<ul class="navbar-nav">
					{if $user->isLoggedIn()}
						<li class="nav-item dropdown">
							<a class="nav-link dropdown-toggle" href="#" id="adminNavbarDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
								<i class="bi bi-gear-fill"></i> Administrace
								{if !empty($updateAvailable)}
									<span class="position-absolute top-2 start-100 translate-middle p-1 bg-danger border border-light rounded-circle" style="margin-top: 5px; margin-left: -5px;">
										<span class="visually-hidden">Aktualizace</span>
									</span>
								{/if}
							</a>
							<ul class="dropdown-menu dropdown-menu-end shadow-sm border-0" aria-labelledby="adminNavbarDropdown">
								<li>
									<a class="dropdown-item" n:href="Admin:default">
										<i class="bi bi-speedometer2 me-2"></i> Nástěnka
									</a>
								</li>
								<li>
									<a class="dropdown-item" n:href="Admin:events">
										<i class="bi bi-calendar-event me-2"></i> Správa akcí
									</a>
								</li>
								<li>
									<a class="dropdown-item" n:href="Admin:settings">
										<i class="bi bi-sliders me-2"></i> Nastavení
									</a>
								</li>
								<li>
									<a class="dropdown-item" n:href="Admin:update">
										<i class="bi bi-arrow-repeat me-2"></i> Aktualizace
										{if !empty($updateAvailable)}
											<span class="badge bg-danger rounded-pill ms-1">Nová</span>
										{/if}
									</a>
								</li>
								<li><hr class="dropdown-divider"></li>
								<li>
									<a class="dropdown-item text-danger" n:href="Admin:logout">
										<i class="bi bi-box-arrow-right me-2"></i> Odhlásit se
									</a>
								</li>
							</ul>
						</li>
					{else}
						<li class="nav-item">
							<a class="nav-link" n:href="Admin:login">
								<i class="bi bi-lock"></i> Admin
							</a>
						</li>
					{/if}
				</ul>
			</div>
		</div>
	</nav>

	{foreach $flashes as $flash}
		<div class="flash-message alert alert-{$flash->type === 'success' ? 'success' : ($flash->type === 'error' ? 'danger' : 'info')} alert-dismissible fade show" role="alert">
			{$flash->message}
			<button type="button" class="btn-close" data-bs-dismiss="alert"></button>
		</div>
	{/foreach}

	<main>
		{include content}
	</main>

	<footer>
		<div class="container text-center">
			<small>
				{$appName} &copy; {date('Y')} · Plánování sdílených jízd pro účastníky akcí · v{App\Core\Version::get()}<br>
				<a n:href="Home:about"><i class="bi bi-heart-fill text-danger"></i> Líbí se vám {$appName}?</a> ·
				<a href="https://github.com/eulal/spolujizda" target="_blank" rel="noopener"><i class="bi bi-github"></i> GNU GPL v3 Open Source</a> ·
				<a n:href="Home:co2Metodologie"><i class="bi bi-leaf"></i> Metodologie CO₂</a> ·
				<a n:href="Home:gdpr"><i class="bi bi-shield-check"></i> Ochrana osobních údajů (GDPR)</a>
			</small>
		</div>
	</footer>

	<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
			integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>

	<script>
		// Auto-dismiss flash messages
		document.querySelectorAll('.flash-message').forEach(el => {
			setTimeout(() => {
				const alert = bootstrap.Alert.getOrCreateInstance(el);
				alert.close();
			}, 5000);
		});
	</script>
</body>
</html>
